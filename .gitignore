prism-ui-prism-reactjs-lib-master/

# Cursor config is local-only, EXCEPT the figma-page-to-prism skill,
# which ships so the page-level map_figma_tree flow works on clone.
.cursor/*
!.cursor/skills/

# Internal design docs / scratch notes stay local (not shipped).
docs/

# Local scratch + npm auth (never commit credentials).
rough.txt
.npmrc

# --- Python ---------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
*.egg

# Virtualenvs
.venv/
venv/
env/

# Secrets — .env is local, .env.example is committed as the contract
.env
*.env
!.env.example

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# uv build artifacts (lockfile and requirements.txt ARE committed)
.uv-cache/

# --- OS / editor ----------------------------------------------------------
.DS_Store
.idea/
.vscode/
*.swp

# --- Runtime cache for prism-mcp (PRD section 5) --------------------------
# Lives at ~/.cache/prism-mcp by default; ignore any local override too.
.prism-mcp-cache/
