# Copy this file to `.env` and fill in the values you need.
# `.env` is git-ignored; `.env.example` is committed as the contract.
#
# All variables below are optional unless noted. The MCP server reads
# them on cold start via src/prism_mcp/config.py.

# --- Figma REST API ---------------------------------------------------------
# REQUIRED for prism-mcp.map_figma_tree (the Figma page walker).
# Personal Access Token for the Figma REST API. Generate one at:
#   https://www.figma.com/developers/api#access-tokens
# Read by src/prism_mcp/figma/fetch.py via os.environ["FIGMA_TOKEN"].
FIGMA_TOKEN=

# --- Optional Figma cache override ------------------------------------------
# Where to cache raw Figma REST responses (1h TTL). Defaults to
# ~/.cache/prism-mcp/figma/ when unset.
# PRISM_MCP_FIGMA_CACHE_DIR=

# --- Nutanix Artifactory (Prism React library acquisition) ------------------
# Required for the slice-2 library fetcher unless you've already populated
# the on-disk cache at ~/.cache/prism-mcp/<version>/package/ manually.
# See src/prism_mcp/config.py: ServerConfig.from_env() for the resolution
# precedence.

# Option A — explicit email + API key (recommended for first-time setup):
# JFROG_EMAIL=you@nutanix.com
# JFROG_API_KEY=AKCp...

# Option B — pre-base64-encoded "email:apikey":
# JFROG_AUTH=YWJjQG51dGFuaXguY29tOkFLQ3A...

# --- TLS overrides for the Nutanix Artifactory chain ------------------------
# The Canaveral root CA is in the macOS Keychain but not in certifi.
# Either point at a PEM bundle or (last-resort) disable verification.
# PRISM_MCP_CA_BUNDLE=/Users/you/.config/prism-mcp/canaveral-root-ca.pem
# PRISM_MCP_INSECURE_TLS=0

# --- Advanced overrides (rarely needed) -------------------------------------
# Where to cache the downloaded Prism tarball + built search indexes.
# Defaults to ~/.cache/prism-mcp/.
# PRISM_MCP_CACHE_DIR=
# Override the Artifactory npm registry root (slash-terminated) or the
# package coordinate. Defaults target Nutanix Canaveral and
# @nutanix-ui/prism-reactjs.
# PRISM_MCP_REGISTRY_URL=
# PRISM_MCP_PACKAGE_NAME=@nutanix-ui/prism-reactjs
